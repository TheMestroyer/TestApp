# Copy this file to .env and fill in real values before running the backend.

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Port the Node server listens on.
PORT=4000

# Set to "true" once the app is served over HTTPS (e.g. behind your production nginx).
# Keep "false" for local http:// development, otherwise the browser will refuse the cookie.
COOKIE_SECURE=false

# Whoever registers (or already registered) with this email becomes an admin — they get
# an "Admin panel" link for adding/editing/removing shared tests everyone else can see.
# Leave blank to have no admin. Checked case-insensitively, re-applied on every backend
# startup so it also works retroactively on an account that already exists.
ADMIN_EMAIL=
