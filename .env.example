# Copy this file to .env (next to docker-compose.yml) before running `docker compose up`.

# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Keep "true" in production (the app is served over HTTPS via your host nginx).
COOKIE_SECURE=true

# Local host port that the frontend container publishes to (bound to 127.0.0.1 only —
# your host nginx reverse-proxies to this port; it is not exposed directly to the internet).
APP_PORT=8081
